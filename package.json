{
  "name": "@mradex77/google-play-scraper",
  "version": "0.3.0",
  "description": "Google Play scraper for Node.js with a fully typed TypeScript API. Fetch app details, search results, top charts, reviews, permissions and data safety from the Play Store.",
  "keywords": [
    "google-play",
    "google-play-scraper",
    "google-play-api",
    "play-store",
    "play-store-api",
    "playstore",
    "scraper",
    "web-scraping",
    "android",
    "android-apps",
    "app-store",
    "app-data",
    "app-reviews",
    "reviews",
    "aso",
    "app-store-optimization",
    "market-research",
    "typescript",
    "nodejs",
    "zod"
  ],
  "homepage": "https://github.com/MrAdex77/google-play-scraper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrAdex77/google-play-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/MrAdex77/google-play-scraper/issues"
  },
  "author": "MrAdex77 (https://github.com/MrAdex77)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.10.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:e2e": "vitest run --project e2e",
    "check:package": "pnpm build && publint && attw --pack .",
    "docs:api": "typedoc",
    "fixtures:update": "tsx scripts/update-fixtures.ts",
    "example": "tsx examples/all-methods.ts",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "cheerio": "1.2.0",
    "lru-cache": "^11.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
